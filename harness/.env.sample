# Azure OpenAI / Foundry endpoint of your AI Foundry account.
# From terraform output: foundry_account endpoint, e.g.
#   https://aif<suffix>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=

# Chat model deployment name (terraform var.model_deployment_name), e.g. kimi-k2-6
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=

# Optional overrides
AGENT_NAME=MafAgentHarness
COMPACTION_MAX_MESSAGES=100
